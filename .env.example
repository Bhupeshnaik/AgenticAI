# ============================================================
# Bank Marketing AI Platform — Environment Variables
# Copy this file to .env and fill in your Azure values
# ============================================================

# ─── Azure OpenAI ────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ─── Azure AI Foundry (Agent Service) ─────────────────────────
AZURE_AI_PROJECT_CONNECTION_STRING=your-project-connection-string
AZURE_AI_PROJECT_ENDPOINT=https://your-project.api.azureml.ms

# ─── Azure Cosmos DB ─────────────────────────────────────────
AZURE_COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-primary-key
AZURE_COSMOS_DATABASE=bank_marketing_ai

# ─── Azure Blob Storage (DAM) ────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_DAM_CONTAINER=digital-assets
AZURE_STORAGE_DOCS_CONTAINER=documents

# ─── Azure AI Search ─────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-search-admin-key
AZURE_SEARCH_INDEX_ASSETS=assets-index
AZURE_SEARCH_INDEX_CAMPAIGNS=campaigns-index
AZURE_SEARCH_INDEX_COMPLIANCE=compliance-index

# ─── Azure Document Intelligence ─────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-docintel.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-doc-intelligence-key

# ─── Azure Communication Services ────────────────────────────
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://your-acs.communication.azure.com/;...
AZURE_COMMUNICATION_EMAIL_SENDER=marketing@yourbank.com

# ─── Azure Service Bus ───────────────────────────────────────
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-sb.servicebus.windows.net/;...
AZURE_SERVICE_BUS_QUEUE_CAMPAIGNS=campaigns-queue
AZURE_SERVICE_BUS_QUEUE_LEADS=leads-queue

# ─── Azure Event Grid ────────────────────────────────────────
AZURE_EVENT_GRID_ENDPOINT=https://your-eg.eventgrid.azure.net/api/events
AZURE_EVENT_GRID_KEY=your-event-grid-key

# ─── Application Settings ─────────────────────────────────────
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Frontend (Vite) ─────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api
